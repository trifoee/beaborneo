# ===========================================
# Environment Variables for Bea Borneo Travel
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===========================================
# Site Configuration
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# Sanity CMS Configuration
# ===========================================
# Get these from your Sanity project dashboard
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-api-token-for-server-side-operations

# ===========================================
# Email Service (Contact Form)
# ===========================================
# Option 1: SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# Option 2: Resend
# RESEND_API_KEY=your-resend-api-key

# Email addresses
CONTACT_EMAIL=hello@beaborneo.com
FROM_EMAIL=noreply@beaborneo.com

# ===========================================
# Analytics (Optional)
# ===========================================
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# Development
# ===========================================
# Enable debug logging
# DEBUG=true
